# Local development
VITE_SUPABASE_URL=https://your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_BACKEND_URL=http://localhost:3001

# Blockchain contract settings (backend only)
# BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# BLOCKCHAIN_PRIVATE_KEY=your_backend_wallet_private_key
# BLOCKCHAIN_CONTRACT_ADDRESS=0xYourContractAddress

# Production/staging
# Set VITE_BACKEND_URL to your deployed backend API endpoint
# VITE_BACKEND_URL=https://api.yourdomain.com
